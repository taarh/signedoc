# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL / BASE_URL: URL of the app (for links in emails: sign link, download link).
# On Vercel set to your deployment URL, e.g. https://signedoc1.vercel.app
APP_URL="http://localhost:3000"
BASE_URL="http://localhost:3000"

# MongoDB. Local: mongodb://localhost:27017/signflow
# Atlas (pour Vercel) : mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/signedoc?retryWrites=true&w=majority
MONGO_URI="mongodb://localhost:27017/signflow"

# Optional. Port for the server (default 3000).
# PORT=3000

# ----- Envoi d'emails (lien de signature + PDF signé) -----
# Sans SMTP, les liens sont affichés dans la console uniquement.
# Sur Vercel : définir ces variables dans Project → Settings → Environment Variables
# pour que les signataires reçoivent les emails avec le lien de signature.
# BASE_URL doit être l’URL du déploiement (ex. https://signedoc1.vercel.app).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="SignFlow <noreply@example.com>"

# Exemple Gmail (mot de passe d'application) :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# MAIL_FROM="SignFlow <votre@gmail.com>"

# ----- Vercel Blob (stockage des PDF sur Vercel) -----
# Créer un Blob store dans Vercel → Storage, puis le token est ajouté automatiquement.
# BLOB_READ_WRITE_TOKEN est défini par Vercel quand un store Blob est lié au projet.
# Sans Blob sur Vercel, les fichiers uploadés ne sont pas accessibles (filesystem éphémère).
